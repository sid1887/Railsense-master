# ============================================
# Railsense - Environment Configuration
# ============================================
# Copy this file to .env.production and fill in actual values

# ============================================
# Node Environment
# ============================================
NODE_ENV=production

# ============================================
# API Configuration
# ============================================
# Public API URL (visible to client)
NEXT_PUBLIC_API_URL=http://localhost:3000

# Internal API URL (used by server)
INTERNAL_API_URL=http://localhost:3000

# ============================================
# Database Configuration
# ============================================
# SQLite database file path
DATABASE_PATH=/app/data/railsense.db

# Database options
DATABASE_TIMEOUT=5000
DATABASE_POOL_SIZE=5

# ============================================
# Weather Integration
# ============================================
# OpenWeatherMap API Key
# Get one free at: https://openweathermap.org/api
OPENWEATHER_API_KEY=your_api_key_here

# Weather data cache TTL (milliseconds)
WEATHER_CACHE_TTL=1800000

# ============================================
# Railway Data Integration
# ============================================
# IRCTC API configuration (if using real data)
IRCTC_API_KEY=your_irctc_key_here
IRCTC_API_URL=https://api.irctc.co.in

# OpenRailwayMap API for signals
RAILWAY_MAP_API_URL=https://maps.openrailwaymap.org

# ============================================
# Analytics Configuration
# ============================================
# Halt reason detection confidence threshold
CONFIDENCE_THRESHOLD=0.6

# Wait time prediction mode ('mock' or 'real')
PREDICTION_MODE=real

# Section analysis update interval (ms)
SECTION_UPDATE_INTERVAL=30000

# ============================================
# Server Configuration
# ============================================
# Server port
PORT=3000

# Host for binding
HOST=0.0.0.0

# ============================================
# Logging Configuration
# ============================================
# Log level: 'debug' | 'info' | 'warn' | 'error'
LOG_LEVEL=info

# Log file path (optional)
LOG_FILE=/app/logs/railsense.log

# ============================================
# Performance Configuration
# ============================================
# Cache TTL for train analytics (seconds)
ANALYTICS_CACHE_TTL=30

# Maximum concurrent API requests
MAX_CONCURRENT_REQUESTS=50

# Request timeout (milliseconds)
REQUEST_TIMEOUT=15000

# ============================================
# Security Configuration
# ============================================
# API rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# CORS settings
CORS_ORIGIN=*
CORS_CREDENTIALS=true

# ============================================
# Monitoring & Health Checks
# ============================================
# Enable health check endpoint
HEALTH_CHECK_ENABLED=true

# Health check interval (ms)
HEALTH_CHECK_INTERVAL=60000

# ============================================
# Development/Production Features
# ============================================
# Enable debug mode (should be false in production)
DEBUG=false

# Enable API documentation
ENABLE_API_DOCS=true

# ============================================
# Third-party Services
# ============================================
# Sentry error tracking (optional)
SENTRY_DSN=

# DataDog monitoring (optional)
DATADOG_APP_KEY=
DATADOG_API_KEY=

# ============================================
# Feature Flags
# ============================================
# Enable real weather API (vs mock data)
FEATURE_REAL_WEATHER=false

# Enable real signal detection (vs mock)
FEATURE_REAL_SIGNALS=false

# Enable historical snapshots
FEATURE_HISTORICAL_SNAPSHOTS=true

# Enable nearby train detection
FEATURE_NEARBY_TRAINS=true
