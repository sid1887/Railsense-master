# RailSense Environment Configuration
# Copy this to .env.local and fill in your values

# API Configuration
NEXT_PUBLIC_API_BASE_URL=http://localhost:3000/api

# Optional: OpenWeather API (for real weather data)
# NEXT_PUBLIC_OPENWEATHER_API_KEY=your_api_key_here

# Optional: OpenRailwayMap
# OPEN_RAILWAY_MAP_URL=https://tiles.openrailwaymap.org

# Demo/Development Mode
NEXT_PUBLIC_DEMO_MODE=true

# Optional: External Train API
# NEXT_PUBLIC_TRAIN_API_URL=your_train_api_url
# NEXT_PUBLIC_TRAIN_API_KEY=your_key
